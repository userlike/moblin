{
  "include": ["src/**/*"],
  "compilerOptions": {
    "outDir": "dist/esm",
    "incremental": true,
    "composite": true,
    "rootDir": "src",
    "target": "ES5",
    "module": "esnext",
    "lib": ["dom", "esnext"],
    "importHelpers": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "moduleResolution": "node",
    "jsx": "preserve",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "declaration": true,
     "declarationDir": "dist/types"
  }
}
